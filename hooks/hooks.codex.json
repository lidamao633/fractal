{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/skills/fractal/scripts/hooks/pre-tool-use.sh\"",
            "statusMessage": "Loading Fractal context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/skills/fractal/scripts/hooks/stop.sh\"",
            "statusMessage": "Checking Fractal memory"
          }
        ]
      }
    ]
  }
}
